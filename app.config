# Logging
ENABLE_LOGGING=true

# Vector Database
CHROMA_DB_PATH=./chroma_langchain_db
COLLECTION_NAME=disaster_events

# Models
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
LLM_MODEL_LOCAL=qwen2.5:0.5b
LLM_MODEL_API=llama-3.3-70b-versatile
USE_API=false

# Retrieval
RETRIEVAL_TOP_K=10
SIMILARITY_THRESHOLD=0.5

# NASA APIs
NASA_API_URL=https://eonet.gsfc.nasa.gov/api/v3/events
GIBS_API_URL=https://gibs.earthdata.nasa.gov/wmts/epsg4326/best
POWER_API_URL=https://power.larc.nasa.gov/api/temporal/daily/point
NASA_DEFAULT_LIMIT=10000
NASA_DEFAULT_DAYS=5475

# Disaster Types (comma-separated key:value pairs)
DISASTER_TYPES=wildfires:Wildfires,floods:Floods,severeStorms:SevereStorms,volcanoes:Volcanoes,earthquakes:Earthquakes,drought:Drought,landslides:Landslides,seaLakeIce:SeaAndLakeIce

# Prompts
SYSTEM_PROMPT=./data/prompts/systemPrompt.txt

# Map Settings
DEFAULT_MAP_CENTER=37.0902,-95.7129
DEFAULT_MAP_ZOOM=4
RISK_ZONE_COLOR_LOW=#FFA500
RISK_ZONE_COLOR_MEDIUM=#FF6B00
RISK_ZONE_COLOR_HIGH=#FF0000
